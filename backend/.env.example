# Neon Postgres connection string
# Create a project at https://console.neon.tech then copy the connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Use 4001 locally if Octis ERP already occupies 4000
PORT=4001
CORS_ORIGIN=http://localhost:3000

# Octis ERP public catalog (multi-client: change slug per client website)
# ERP_API_URL may be https://host or https://host/api
ERP_API_URL=http://localhost:4000/api
ERP_STORE_SLUG=your-org-slug
# Optional: pin V1 to one branch (defaults to org's first active branch on ERP)
# ERP_BRANCH_ID=
